{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "spotifydfshubhamjain"
		},
		"Spotifyadlsls_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'Spotifyadlsls'"
		},
		"Spotifydbls_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'Spotifydbls'"
		},
		"Spotifyadlsls_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://spotifysashubhamjain.dfs.core.windows.net/"
		},
		"Spotifydbls_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "spotifyservershubhamjain.database.windows.net"
		},
		"Spotifydbls_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "spotify_db"
		},
		"Spotifydbls_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "shubhamjain9014"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "spotifydfshubhamjain_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"Spotifyadlsls_accountKey": {
						"value": "[parameters('Spotifyadlsls_accountKey')]"
					},
					"Spotifydbls_password": {
						"value": "[parameters('Spotifydbls_password')]"
					},
					"Spotifyadlsls_properties_typeProperties_url": {
						"value": "[parameters('Spotifyadlsls_properties_typeProperties_url')]"
					},
					"Spotifydbls_properties_typeProperties_server": {
						"value": "[parameters('Spotifydbls_properties_typeProperties_server')]"
					},
					"Spotifydbls_properties_typeProperties_database": {
						"value": "[parameters('Spotifydbls_properties_typeProperties_database')]"
					},
					"Spotifydbls_properties_typeProperties_userName": {
						"value": "[parameters('Spotifydbls_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}